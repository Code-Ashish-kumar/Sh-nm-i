# ─── PRODUCTION ENV (Render) ─────────────────────────────────────────
NODE_ENV=production

# Database (Neon — free PostgreSQL with pgvector)
DATABASE_URL=postgresql://user:pass@ep-xyz.us-east-2.aws.neon.tech/dbname?sslmode=require

# Server
PORT=5000
CORS_ORIGIN=https://your-app.vercel.app

# Auth
JWT_SECRET=generate-a-strong-random-string-here

# LLM Provider
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_key

# Embeddings (HuggingFace — free, replaces Ollama in production)
HF_API_KEY=hf_your_huggingface_token

# Web search (Tavily — optional, 1000 free req/month)
TAVILY_API_KEY=tvly-your-key

# File storage (Cloudinary — 25GB free)
CLOUDINARY_URL=cloudinary://key:secret@cloud_name

# Job queue (Upstash Redis — free 10k commands/day)
REDIS_URL=rediss://default:token@your-instance.upstash.io:6379
